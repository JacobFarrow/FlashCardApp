<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashcardApp.QuizPage"
             Title="Quiz">

    <StackLayout Padding="16" Spacing="16" VerticalOptions="Center">

        <Label x:Name="ProgressLabel"
               Text="Card 1 of 10"
               HorizontalOptions="Center" />

        <Frame x:Name="FlashcardFrame"
               BorderColor="Gray"
               CornerRadius="12"
               Padding="24"
               MinimumHeightRequest="200">

            <StackLayout VerticalOptions="Center" Spacing="16">

                <Label x:Name="QuestionLabel"
                       Text="Question goes here"
                       FontSize="20"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <Label x:Name="AnswerLabel"
                       Text="Tap card to reveal answer"
                       FontSize="18"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="Gray"
                       IsVisible="True" />

            </StackLayout>

        </Frame>

        <Button x:Name="RevealButton"
                Text="Reveal Answer"
                Clicked="OnRevealClicked" />

        <StackLayout x:Name="ScoreButtons"
                     Orientation="Horizontal"
                     Spacing="16"
                     IsVisible="False"
                     HorizontalOptions="Center">

            <Button Text="Got it!"
                    BackgroundColor="Green"
                    TextColor="White"
                    Clicked="OnGotItClicked" />

            <Button Text="Missed it"
                    BackgroundColor="Red"
                    TextColor="White"
                    Clicked="OnMissedItClicked" />

        </StackLayout>

    </StackLayout>

</ContentPage>